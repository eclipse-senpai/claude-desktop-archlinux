diff --git a/scripts/launcher-common.sh b/scripts/launcher-common.sh
index ab877e4..987ed9e 100755
--- a/scripts/launcher-common.sh
+++ b/scripts/launcher-common.sh
@@ -73,9 +73,12 @@ build_electron_args() {
 		return
 	fi
 
-	# Wayland: deb/nix packages need --no-sandbox in both modes
-	[[ $package_type == 'deb' || $package_type == 'nix' ]] \
-		&& electron_args+=('--no-sandbox')
+	# Wayland: deb/nix pass --no-sandbox only when CLAUDE_ENABLE_SANDBOX=0.
+	# Arch defaults to sandbox on; set CLAUDE_ENABLE_SANDBOX=0 to disable.
+	if [[ ${CLAUDE_ENABLE_SANDBOX:-1} != 1 ]]; then
+		[[ $package_type == 'deb' || $package_type == 'nix' ]] \
+			&& electron_args+=('--no-sandbox')
+	fi
 
 	if [[ $use_x11_on_wayland == true ]]; then
 		# Default: Use X11 via XWayland for global hotkey support
